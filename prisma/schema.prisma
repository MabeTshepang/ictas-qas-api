generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
  MODERATOR
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}
enum TenantType {
  NORMAL    
  MODERATOR 
}

model Tenant {
  id        String   @id @default(cuid())
  name         String       // e.g., "BAMB"
  subtitle     String?      // e.g., "Botswana Agricultural Marketing Board"
  status       TenantStatus @default(ACTIVE)
  type      TenantType   @default(NORMAL) // <--- Add this line
  // Stores overlay colors, image paths, etc.
  branding     Json?        
  
  createdAt    DateTime     @default(now())

  // Relations: These allow "lookup" in Prisma
  users        User[]
  logs         Log[]
}

model User {
  id           String   @id @default(cuid())
  fullName     String  // Or just String if it's required
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  
  // Link to Tenant Table
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  logs         Log[]
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model Log {
  id        String   @id @default(cuid())
  userId    String
  action    String
  status    String   // "Sent", "Failed", or "Stored"
  metadata  Json?
  filePath  String?
  
  // Link to Tenant Table
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}