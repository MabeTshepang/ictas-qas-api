generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model log {
  id        String   @id @default(cuid())
  userId    String
  action    String
  status    String
  metadata  String?  @db.LongText
  filePath  String?
  tenantId  String
  createdAt DateTime @default(now())
  tenant    tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, map: "Log_tenantId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Log_userId_fkey")

  @@index([tenantId, createdAt], map: "Log_tenantId_createdAt_idx")
  @@index([userId], map: "Log_userId_fkey")
}
model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique(map: "PasswordReset_token_key")
  userId    String
  tenantId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  tenant    tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, map: "PasswordReset_tenantId_fkey")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "PasswordReset_userId_fkey")

  @@index([tenantId], map: "PasswordReset_tenantId_idx")
  @@index([userId], map: "PasswordReset_userId_fkey")
  
  @@map("passwordreset") 
}

model tenant {
  id            String          @id @default(cuid())
  name          String
  subtitle      String?
  status        tenant_status   @default(ACTIVE)
  type          tenant_type     @default(NORMAL)
  branding      String?         @db.LongText
  fileSlug      String
  createdAt     DateTime        @default(now())
  log           log[]
  passwordResets PasswordReset[]
  users          user[]
}

model user {
  id            String          @id @default(cuid())
  fullName      String
  email         String          @unique(map: "User_email_key")
  passwordHash  String
  role          user_role       @default(USER)
  tenantId      String
  createdAt     DateTime        @default(now())
  log           log[]
  passwordResets PasswordReset[]
  tenant        tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, map: "User_tenantId_fkey")

  @@index([tenantId], map: "User_tenantId_idx")
}

enum tenant_status {
  ACTIVE
  INACTIVE
}

enum tenant_type {
  NORMAL
  MODERATOR
}

enum user_role {
  ADMIN
  USER
  MODERATOR
}
