{
  "openapi": "3.0.0",
  "info": {
    "title": "ICTAS Subsystem Multi-Tenant API",
    "version": "1.0.0",
    "description": "Comprehensive API documentation for System Administrators, Moderators, and Tenant Users.",
    "contact": "Tshepang Mabe"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/tenants/public": {
      "get": {
        "tags": ["Public"],
        "summary": "Get public tenant branding",
        "security": [],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User Login",
        "security": [],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Request password reset email",
        "security": [],
        "responses": { "200": { "description": "Email sent" } }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Reset password with token",
        "security": [],
        "responses": { "200": { "description": "Password updated" } }
      }
    },
    "/api/admin/stats": {
      "get": {
        "tags": ["Admin & Moderator"],
        "summary": "Get global dashboard statistics",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/admin/logs": {
      "get": {
        "tags": ["Admin & Moderator"],
        "summary": "Get system logs",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/admin/users": {
      "get": { "tags": ["User Management"], "summary": "Get all users", "responses": { "200": { "description": "Success" } } },
      "post": { "tags": ["User Management"], "summary": "Create new user", "responses": { "201": { "description": "Created" } } }
    },
    "/api/admin/users/{id}": {
      "patch": { "tags": ["User Management"], "summary": "Update user", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Updated" } } },
      "delete": { "tags": ["User Management"], "summary": "Delete user", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Deleted" } } }
    },
    "/api/admin/moderator/users": {
      "get": { "tags": ["Moderator Management"], "summary": "Get all moderators", "responses": { "200": { "description": "Success" } } },
      "post": { "tags": ["Moderator Management"], "summary": "Invite a new moderator", "responses": { "201": { "description": "Invited" } } }
    },
    "/api/admin/moderator/users/{id}": {
      "delete": { "tags": ["Moderator Management"], "summary": "Remove moderator", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Removed" } } }
    },
    "/api/tenants/logs": {
      "get": { "tags": ["Tenant Management"], "summary": "Get all tenant-specific logs", "responses": { "200": { "description": "Success" } } }
    },
    "/api/tenants/all": {
      "get": { "tags": ["Tenant Management"], "summary": "Get all tenants (Moderator view)", "responses": { "200": { "description": "Success" } } }
    },
    "/api/tenants/stats": {
      "get": { "tags": ["Tenant Management"], "summary": "Get moderator dashboard stats", "responses": { "200": { "description": "Success" } } }
    },
    "/api/tenants": {
      "post": {
        "tags": ["Tenant Management"],
        "summary": "Create tenant (with file upload)",
        "requestBody": { "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" }, "name": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/tenants/{id}": {
      "patch": { 
        "tags": ["Tenant Management"], 
        "summary": "Update tenant", 
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } } },
        "responses": { "200": { "description": "Updated" } } 
      },
      "delete": { "tags": ["Tenant Management"], "summary": "Delete tenant", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Deleted" } } }
    },
    "/api/user/password": {
      "patch": { "tags": ["User Profile"], "summary": "Update personal password", "responses": { "200": { "description": "Updated" } } }
    },
    "/api/upload": {
      "post": {
        "tags": ["File Actions"],
        "summary": "Upload file to processing engine",
        "requestBody": { "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } } },
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/logs/{logId}/re-email": {
      "post": { "tags": ["File Actions"], "summary": "Resend processed file via email", "parameters": [{ "name": "logId", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Sent" } } }
    },
    "/api/logs/{logId}": {
      "patch": { "tags": ["File Actions"], "summary": "Update a log entry", "parameters": [{ "name": "logId", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Updated" } } }
    },
    "/api/files": {
      "get": { "tags": ["File Actions"], "summary": "Get all accessible files", "responses": { "200": { "description": "Success" } } }
    },
    "/api/files/{id}": {
      "get": { "tags": ["File Actions"], "summary": "Get file details", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Success" } } },
      "delete": { "tags": ["File Actions"], "summary": "Delete file record (Admin only)", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Deleted" } } }
    },
    "/api/my-logs": {
      "get": { "tags": ["User Profile"], "summary": "Get current user logs", "responses": { "200": { "description": "Success" } } }
    },
    "/api/logs": {
      "post": { "tags": ["File Actions"], "summary": "Create a manual log entry", "responses": { "201": { "description": "Created" } } }
    }
  }
}